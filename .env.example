# Backend Environment Variables
# Copy this to .env and fill in your values

# MongoDB connection string (get from MongoDB Atlas or use local)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/samtech?retryWrites=true&w=majority

# JWT secret for authentication (generate a random string, e.g., use openssl rand -hex 32)
JWT_SECRET=your-super-secret-jwt-key-change-this

# Frontend URL for CORS
CLIENT_URL=http://localhost:5173

# Server port (optional, defaults to 5000)
PORT=5000

